{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Discord API Embed Object",
  "description": "JSON schema for discord embed object, based on official API docs",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 256,
      "description": "title of the embed"
    },
    "type": {
      "type": "string",
      "enum": ["rich", "image", "video", "gifv", "article", "link"],
      "description": "type of embed (for webhook embeds use 'rich')"
    },
    "description": {
      "type": "string",
      "maxLength": 4096,
      "description": "description of the embed"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the embed"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of embed content"
    },
    "color": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16777215,
      "description": "embed color as integer"
    },
    "footer": {
      "type": "object",
      "additionalProperties": false,
      "description": "footer information",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "maxLength": 2048,
          "description": "footer text"
        },
        "icon_url": {
          "type": "string",
          "format": "uri",
          "description": "URL of footer icon (HTTP(S) or attachment://...)"
        },
        "proxy_icon_url": {
          "type": "string",
          "format": "uri",
          "description": "proxied URL of footer icon"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "description": "image information",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "source URL of image"
        },
        "proxy_url": {
          "type": "string",
          "format": "uri",
          "description": "proxied URL of the image"
        },
        "height": {
          "type": "integer",
          "minimum": 0,
          "description": "height of image"
        },
        "width": {
          "type": "integer",
          "minimum": 0,
          "description": "width of image"
        }
      }
    },
    "thumbnail": {
      "type": "object",
      "additionalProperties": false,
      "description": "thumbnail information",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "source URL of thumbnail"
        },
        "proxy_url": {
          "type": "string",
          "format": "uri",
          "description": "proxied URL of the thumbnail"
        },
        "height": {
          "type": "integer",
          "minimum": 0,
          "description": "height of thumbnail"
        },
        "width": {
          "type": "integer",
          "minimum": 0,
          "description": "width of thumbnail"
        }
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "description": "video information",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "source URL of video"
        },
        "proxy_url": {
          "type": "string",
          "format": "uri",
          "description": "proxied URL of the video"
        },
        "height": {
          "type": "integer",
          "minimum": 0,
          "description": "height of video"
        },
        "width": {
          "type": "integer",
          "minimum": 0,
          "description": "width of video"
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "description": "provider information",
      "properties": {
        "name": {
          "type": "string",
          "description": "name of provider"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL of provider"
        }
      }
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "description": "author information",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 256,
          "description": "name of author"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL of author"
        },
        "icon_url": {
          "type": "string",
          "format": "uri",
          "description": "URL of author icon (HTTP(S) or attachment://...)"
        },
        "proxy_icon_url": {
          "type": "string",
          "format": "uri",
          "description": "proxied URL of author icon"
        }
      }
    },
    "fields": {
      "type": "array",
      "maxItems": 25,
      "description": "fields information",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 256,
            "description": "field name"
          },
          "value": {
            "type": "string",
            "maxLength": 1024,
            "description": "field value"
          },
          "inline": {
            "type": "boolean",
            "description": "whether field is inline"
          }
        }
      }
    }
  }
}
